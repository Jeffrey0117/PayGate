# PayGate Configuration

# Server port
PORT=4019

# Admin API bearer token (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PAYGATE_TOKEN=

# Incoming webhook auth secret (for POST /api/webhook)
PAYGATE_WEBHOOK_SECRET=

# PAYUNi payment provider (optional — only needed if using PAYUNi integration)
PAYUNI_MERCHANT_ID=
PAYUNI_HASH_KEY=
PAYUNI_HASH_IV=
